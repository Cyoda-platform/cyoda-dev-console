{
  "name": "dev-console",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "tauri:dev": ". \"$HOME/.cargo/env\" && tauri dev",
    "tauri:build": ". \"$HOME/.cargo/env\" && tauri build",
    "lint:rust": ". \"$HOME/.cargo/env\" && cargo fmt --check --manifest-path src-tauri/Cargo.toml && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings"
  },
  "dependencies": {
    "@cyoda/agent-bridge-contract": "workspace:*",
    "@cyoda/console-design-system": "workspace:*",
    "@cyoda/console-shell": "workspace:*",
    "@cyoda/entity-model-viewer": "workspace:*",
    "@cyoda/workflow-core": "file:../../../cyoda-workflow-editor/packages/workflow-core",
    "@cyoda/workflow-editor-host": "workspace:*",
    "@cyoda/workflow-file-indexer": "workspace:*",
    "@cyoda/workflow-graph": "file:../../../cyoda-workflow-editor/packages/workflow-graph",
    "@cyoda/workflow-layout": "file:../../../cyoda-workflow-editor/packages/workflow-layout",
    "@cyoda/workflow-monaco": "file:../../../cyoda-workflow-editor/packages/workflow-monaco",
    "@cyoda/workflow-project-model": "workspace:*",
    "@cyoda/workflow-react": "file:../../../cyoda-workflow-editor/packages/workflow-react",
    "@cyoda/workflow-viewer": "file:../../../cyoda-workflow-editor/packages/workflow-viewer",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-virtual": "^3.11.0",
    "@tauri-apps/api": "^2.1.0",
    "monaco-editor": "0.52.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "uuid": "^11.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "happy-dom": "^15.11.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
