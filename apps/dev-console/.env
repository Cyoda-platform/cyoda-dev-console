# Env file loaded by Vite (and `tauri dev`). Note: this repo does NOT gitignore .env,
# so committing it turns the flag on for everyone on the branch.
# Turn on the BYO AI "AI Agent" surface (Connect / Bundle / Profiles).
VITE_FEATURE_FLAG_AGENT=true
# Turn on the embedded LLM Assistant tab (BYO API key; propose + apply workflow edits).
VITE_FEATURE_FLAG_CHATBOT=true
