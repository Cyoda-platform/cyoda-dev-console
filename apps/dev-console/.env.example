# Mount the /agent route (Connect / Bundle / Profiles).
# The route is hidden when this flag is missing or set to anything other than "true".
VITE_FEATURE_FLAG_AGENT=false

# Show the embedded LLM Assistant tab (BYO API key; proposes + applies workflow edits).
# Requires VITE_FEATURE_FLAG_AGENT=true as well, since it is a tab inside the agent surface.
VITE_FEATURE_FLAG_CHATBOT=false
