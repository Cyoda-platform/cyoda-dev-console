{
  "name": "cyoda-dev-console",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "engines": { "node": ">=22", "pnpm": ">=9" },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "tauri:dev": "pnpm --filter dev-console tauri:dev",
    "tauri:build": "pnpm --filter dev-console tauri:build"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
